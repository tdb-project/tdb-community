# ─────────────────────────────────────────────────
# TDB Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────

# API key — required for all authenticated endpoints
# Generate one: python3 -c "import secrets; print(secrets.token_hex(32))"
TDB_API_KEYS=CHANGE-ME-IN-PRODUCTION

# Server port (default 8000)
TDB_PORT=8000

# Log level: DEBUG | INFO | WARNING | ERROR
TDB_LOG_LEVEL=INFO

# Audit log file path
TDB_LOG_FILE=logs/tdb_audit.jsonl

# SQLite file that stores the source registry
# Backed by a Docker volume — survives container restarts
TDB_REGISTRY_DB=data/tdb_registry.db

# ── Docker only ──────────────────────────────────
# Directory on the HOST where your CSV files live.
# Mounted read-only into the container at /data.
# Register sources using file_path: /data/your_file.csv
TDB_DATA_DIR=./data

# ── Security: confine CSV paths ──────────────────
# When set, registered CSV file_path values must resolve to a path INSIDE this
# directory (symlinks and ".." are resolved first); anything outside is rejected
# with 403. Unset = no restriction. This is an in-container/app path, distinct
# from TDB_DATA_DIR above (the host dir). The Docker image already defaults this
# to /data, so you normally don't set it here. For a bare `tdb serve`, point it
# at the folder holding your CSVs to lock the server down.
# TDB_ALLOWED_DATA_DIR=/data
